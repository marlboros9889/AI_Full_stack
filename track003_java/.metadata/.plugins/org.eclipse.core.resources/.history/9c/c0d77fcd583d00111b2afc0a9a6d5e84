package com.the703.basic013;

class Coffee {
	String name; int price, num;

	public Coffee() {
		super();
		
		this.name = "아메리카노";
		this.num = 1;
		this.price =2000;
	}



	public Coffee(String name, int price, int num) {
		super();
		this.name = name;
		this.num = num;
		this.price = price;
	}



	@Override
	public String toString() {
		return "Coffee [name=" + name + ", price=" + price + ", num=" + num + "]";
	}



	void show() {
		System.out.println("====커피메뉴====");
		System.out.println( name+"\t"+num+"\t"+price*num);
	}
}

public class ClassEx003 {
	public static void main(String[] args) {
        // 1. 정보를 직접 넣어서 생성
        Coffee a1 = new Coffee("까페라떼",4000 , 2);  //1) new 객체생성 2)초기화 "까페라떼",2,4000  3)주소
        a1.show();

        // 2. 아무 정보 없이 생성 (기본값 아메리카노 출력)
        Coffee a2 = new Coffee(); //1) new 객체생성 2)초기화 "아메리카노",1,2000  3)주소
        a2.show();
		 
//          출력내용 :
//        	=====커피
//        	커피명 : 까페라떼
//        	커피잔수 : 2 
//        	커피가격 : 8000
//        	=====커피
//        	커피명 : 아메리카노
//        	커피잔수 : 1
//        	커피가격 : 2000
	 }
}
