package com.the703.basic012;
//멤버변수 : String name;  int no, kor, eng, math;
//멤버함수 : void info()
//1. 클래스는 부품객체
//2. 상태(멤버변수)와 행위(멤버함수)
//3. 설계도> 부품객체> 사용
	class Student001{
	//멤버변수
	String name; int no, kor, eng, math;
	//멤버함수
	void info(){ 
		System.out.println("이름: " + name );
		System.out.println("총점: " + (kor+eng+math));
		System.out.printf("평균:%.2f ",(kor+eng+math)/3.0);
	}
}
public class Class001_ex {
	public static void main(String[] args) {
		// TODO Auto-generated method stub

		  Student001 s1 = new Student001();
		  			//1) new 번지,객체생성 /2)생성자-초기화 /3)s1주소
		     s1.name="first"; 
		     s1.no=11;
		     s1.kor=100; 
		     s1.eng=100; 
		     s1.math=99;
		     s1.info();
	}

}
