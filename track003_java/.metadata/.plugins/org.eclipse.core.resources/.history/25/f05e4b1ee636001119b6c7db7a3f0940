package com.the703.basic010;

public class Arr001 {
	public static void main(String[] args) {

		//인덱스 꺼내쓰기  1차원 배열 사용하기
		//1. 변수 활용하기
		int a=1, b=2, c=3;
		
		//2. 배열이란?
		/*
		 *  [같은 타입] 의 데이터를 [연속된 공간에 저장] 하는 자료구조
		 *  - 각 데이터의 저장 위치[인덱스]를 통해서 접근
		 *  - 1) int [ ] arr 주소 보관할 준비 
		 *  - 2) null 공간은 있지만 값이 없음
		  */
		int [ ] arr = null;
		System.out.println(arr);
		
		//[ stack ] arr2 주소보관 =  [heap] 1,2,3 연속된 공간에 저장
		int [ ] arr2          =           {1,2,3};  //3개 0부터2까지
        //  arr2(1000번지)      >     1000번지 { 1, 2, 3 }
		//                                    [0] [1] [2]
		System.out.println(arr2); // 출력시 : [I@2f92e0f4
		
		System.out.println("1꺼내 쓰기 > " + arr2[0]);
		System.out.println("1꺼내 쓰기 > " + arr2[1]);
		System.out.println("1꺼내 쓰기 > " + arr2[2]);
		
		
		
		
		
		
		
		
		
		
	}

}
