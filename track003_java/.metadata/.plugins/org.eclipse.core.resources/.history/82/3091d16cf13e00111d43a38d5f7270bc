package ClassEX;

public static void info() {
    System.out.println("=== 성적 출력 프로그램 ===");
    System.out.printf("%-10s %5s %5s %5s %6s %6s %4s %6s %6s%n",
            "이름", "국어", "영어", "수학", "총점", "평균", "등급", "합불", "장학금");
    System.out.println("-".repeat(60));
}

public void show() {
    // 계산
    total = kor + eng + math;
    aver  = total / 3.0;

    // 등급 (rank)
    if      (aver >= 90) rank = "수";
    else if (aver >= 80) rank = "우";
    else if (aver >= 70) rank = "미";
    else if (aver >= 60) rank = "양";
    else                 rank = "가";

    // 합불 (p)
    p = (aver >= 60) ? "합격" : "불합격";

    // 장학금 (s)
    if      (aver >= 90) s = "1등급";
    else if (aver >= 80) s = "2등급";
    else                 s = "없음";

    System.out.printf("%-10s %5d %5d %5d %6d %6.1f %4s %6s %6s%n",
            name, kor, eng, math, total, aver, rank, p, s);
}
import Class000.Score;

