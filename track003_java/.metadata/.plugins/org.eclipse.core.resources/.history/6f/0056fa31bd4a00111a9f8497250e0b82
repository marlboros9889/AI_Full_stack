package basic.basic016_ex;

import java.io.File;
import java.io.FileNotFoundException;
import java.io.FileReader;
import java.io.FileWriter;
import java.io.IOException;
import java.text.SimpleDateFormat;

public class JavaIOEx001 {
	public static void main(String[] args) {
	
		//#1. 경로
		SimpleDateFormat sdf =new SimpleDateFormat("yyyyMMdd_HHmmss"); // 포맷설정
		long millis = System.currentTimeMillis();	//시스템 시간 가져오기
		String folder_rel = "src/basic/basic016_ex";	//상대경로 - 현재 작업 중인 폴더 기준
		String file_path = "app.log";
		
		File folder = new File(folder_rel);
		File file = new File(folder_rel + file_path);
		
		//#2. 파일+폴더 준비  ( exists, mkdirs, createNewFile)
		if(! folder.exists()) { folder.mkdirs(); }
		if(! file.exists()) { 
			try { file.createNewFile(); } catch (IOException e) {
				e.printStackTrace(); }}
		
		
		
		//#3. Char 단위로 파일 쓰기
		//     sdf.format(millis) + "로그 파일입니다."    20260508_1716  로그파일입니다.
		try ( FileWriter fw = new FileWriter(file)){
			String logMessage = sdf.format(millis) + "로그파일입니다";
			fw.write(logMessage);
			System.out.println("파일쓰기 완료:"+ logMessage);		
			fw.close();
		} catch (IOException e) { e.printStackTrace(); }
		
		
		
		
		//#4. Char 단위로 파일 읽기
		try {
			FileReader fr= new FileReader(file);
			int ch;
			try {
				while(  (ch=fr.read())!=-1 )
				System.out.print( (char) ch );
				fr.close();
			} catch (IOException e) {
				e.printStackTrace();
			}
		 }
		
		
		
	}
}
