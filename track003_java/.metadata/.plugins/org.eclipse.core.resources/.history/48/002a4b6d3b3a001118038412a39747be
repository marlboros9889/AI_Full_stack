package com.the703.v1;

import java.util.Scanner;

public class Bankproject_Exv6 {

	public static void main(String[] args) {
		// TODO Auto-generated method stub
		
        // [변수 설정] 3명까지 저장 가능한 배열
		String[] id = new String[3];      
		String[] pass = new String[3];    
		double[] balance = new double[3]; 

		int menu = -1;
		int count = 0; // 현재 가입된 사용자 수 체크용
		Scanner sc = new Scanner(System.in);

for (;;) {
    System.out.println("\n======= BANK SYSTEM (ver2. Array) =======");
System.out.println("[1] 추가 [2] 조회 [3] 입금 [4] 출금 [5] 삭제 [9] 종료");
System.out.print("👉 선택: ");
menu = sc.nextInt();

if (menu == 9) {
    System.out.println("프로그램을 종료합니다.");
    break;
}

switch (menu) {
    case 1: // 추가 기능
System.out.println("\n[계좌 추가]");
if (count >= 3) {
    System.out.println("❌ 더 이상 계좌를 생성할 수 없습니다. (최대 3개)");
} else {
    System.out.print("ID 입력: ");
id[count] = sc.next();
System.out.print("PASS 입력: ");
pass[count] = sc.next();
System.out.print("초기 입금액: ");
balance[count] = sc.nextDouble();
System.out.println("✅ " + id[count] + "님, 계좌가 생성되었습니다.");
count++; // 다음 저장 공간으로 이동
    }
    break;

case 2: // 조회 기능
System.out.println("\n[계좌 조회]");
System.out.print("아이디 입력: ");
String searchId = sc.next();
System.out.print("비밀번호 입력: ");
String searchPass = sc.next();

boolean found = false;
for (int i = 0; i < count; i++) {
    if (id[i].equals(searchId) && pass[i].equals(searchPass)) {
        System.out.println("💰 " + id[i] + "님의 잔액은 " + balance[i] + "원입니다.");
        found = true;
        break;
    }
}
if (!found) System.out.println("❌ 정보를 찾을 수 없습니다.");
    break;

case 3: // 입금 기능
System.out.println("\n[입금 기능]");
System.out.print("아이디 입력: ");
String depositId = sc.next();
for (int i = 0; i < count; i++) {
    if (id[i].equals(depositId)) {
        System.out.print("입금액: ");
double money = sc.nextDouble();
balance[i] += money;
System.out.println("✅ 입금 완료! 현재 잔액: " + balance[i]);
        }
    }
    break;

case 4: // 출금 기능 (생략 가능 - 입금과 유사)
System.out.println("출금 기능입니다.");
    break;

case 5: // 삭제 기능
System.out.println("삭제 기능입니다.");
// 실제 구현 시 해당 인덱스 데이터를 null/0으로 초기화
    break;

default:
    System.out.println("번호를 다시 확인해주세요.");
            }
        }
        sc.close();
    }

		
	}


