package com.the703.basic010;

public class Arr2002 {

	public static void main(String[] args) {
		// TODO Auto-generated method stub
		//1. 값을 알고 있는 경우
		int [][] arr2 = {
				{1,2,3} ,//00, 01, 02
				{4,5,6} ,//10, 11, 12,
						};
		//2. 값을 모르는 경우
		
		
		int data=10;
		
		arr2[0][0] = data; data+=10;
		arr2[0][1] = data; data+=10; 
		arr2[0][2] = data; data+=10; 
		arr2[1][0] = data; data+=10; 
		arr2[1][1] = data; data+=10; 
		arr2[1][2] = data; data+=10; 

		for(int ch=0; ch<arr2.length; ch++) {
		 for(int i=0; i<arr2.length; i++) {
			  System.out.println(arr2[ch][i]+ "\t");
		 }
		}
	}

}
