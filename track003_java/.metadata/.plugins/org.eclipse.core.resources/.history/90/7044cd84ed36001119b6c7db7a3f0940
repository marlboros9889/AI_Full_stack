package com.the703.basic010;

public class Arr002_ex {
	public static void main(String[] args) {
	
//	    1. 배열명 : arr
//	    2. 값 넣기 : 'A' , 'B' , 'C' , 'D'
//	    3. for + length 로 출력
		
		char[] arr = {'A','B','C','D'};
		for(int i=0; i<=4; i++)	
		{System.out.println(arr[i]);}
		
		
		System.out.println();
		System.out.println();
		System.out.println();
		System.out.println(arr.length);
		for(int i=0; i<arr.length; i++)	
		{System.out.println(arr[i]);}
		
	}

}
