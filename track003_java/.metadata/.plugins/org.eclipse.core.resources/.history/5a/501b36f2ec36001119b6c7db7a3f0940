package com.the703.basic010;

public class Arr003_ex {
	public static void main(String[] args) {
//		  1. 배열명 : arr
//		    2. 값 넣기 : "아이언맨" , "헐크" , "캡틴"
//		    3. for + length 로 출력

		String [] arr= {"아이언맨","헐크","캡틴"};
		for(int i=0; i<=3; i++){System.out.println(arr[i]);}
		
		
		System.out.println();
		System.out.println();
		System.out.println(arr.length);
		for(int i=0; i<=3; i++) {System.out.println(arr[i]);}
		

	}

}
