package com.the703.v1;
import java.util.Scanner;
public class Bankproject_v5 {

	public static void main(String[] args) {

		 //변수                          0   1    2
		  String []id=new String[3];       //  one two three
		  String []pass = new String[3];   // 1111 2222 3333
		  double []balance = new double[3];// 1100 2200 3300   
		      int menu=-1;  
		      Scanner sc = new Scanner(System.in);
		   
		
				// 계좌 추가 로직 (menu == 1)
				if (menu == 1) {
					boolean isCreated = false; // 생성 성공 여부 확인
					for (int i = 0; i < id.length; i++) {
						if (id[i] == null) { // 배열에 빈 공간(null)이 있는지 확인
							System.out.print("아이디 입력> ");
							id[i] = sc.next();
							System.out.print("비밀번호 입력> ");
							pass[i] = sc.next();
							System.out.print("초기 잔액 입력> ");
							balance[i] = sc.nextDouble();

							System.out.println((i + 1) + "번째 계좌가 생성되었습니다!");
							isCreated = true;
							break; // 계좌를 만들었으니 반복문을 즉시 빠져나옴
						}
					}
					// 3칸이 모두 꽉 찼을 경우
					if (!isCreated) {
						System.out.println("더 이상 계좌를 추가할 수 없습니다 (최대 3개).");
					}
				}

				// 사용자 인증 및 입출금 (menu 2~5)
				else if (menu >= 2 && menu <= 5) {
					System.out.print("아이디 입력> ");
					String tempId = sc.next();
					System.out.print("비밀번호 입력> ");
					String tempPass = sc.next();

					int loggedInIndex = -1; // 로그인에 성공한 사용자의 '방 번호'를 저장할 변수

					// 0~2번 방을 돌면서 입력한 정보와 일치하는지 확인
					for (int i = 0; i < id.length; i++) {
						// String 비교는 == 대신 .equals()를 사용해야 합니다.
						if (id[i] != null && id[i].equals(tempId) && pass[i].equals(tempPass)) {
							loggedInIndex = i; // 일치하는 방 번호를 기억함!
							break; // 찾았으니 더 이상 찾을 필요 없음
						}
					}

					if (loggedInIndex == -1) {
						System.out.println("정보를 확인해주세요. 일치하는 계좌가 없습니다.");
						continue; // 다시 메뉴 선택으로 돌아감
					}

					// 인증 성공! 기억해둔 방 번호(loggedInIndex)를 사용하여 작업 수행
					switch (menu) {
					case 2:
						System.out.printf("ID : %s\nPASS : %s\nBALANCE : %.0f\n", id[loggedInIndex],
								pass[loggedInIndex], balance[loggedInIndex]);
						break;
					case 3:
						System.out.print("입금할 금액 > ");
						balance[loggedInIndex] += sc.nextDouble(); // 해당 고객의 잔액만 증가
						System.out.println("입금 완료!");
						break;
					// ... (출금, 삭제도 동일하게 loggedInIndex를 활용해 구현)
					}
				}
	
}
}
