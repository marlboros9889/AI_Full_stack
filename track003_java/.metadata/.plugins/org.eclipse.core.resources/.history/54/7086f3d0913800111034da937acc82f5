package com.the703.basic010;

import java.util.Arrays;

public class Arr2001 {

	public static void main(String[] args) {
		// TODO Auto-generated method stub
		int [][] arr2 = {
				{1,2,3} ,//00, 01, 02
				{4,5,6} ,//10, 11, 12,
		};
		
		System.out.println(arr2);
		System.out.println(Arrays.toString(arr2));
		
		//ver-1 눈에 보이는대로
		
		System.out.print(arr2[0][0]+"\t");
		System.out.print(arr2[0][1]+"\t");
		System.out.print(arr2[0][2]+"\t"); System.out.println();
		
		
		System.out.print(arr2[1][0]+"\t");
		System.out.print(arr2[1][1]+"\t");
		System.out.print(arr2[1][2]+"\t"); System.out.println();
		
		//ver-2  
		for(int kan=0; kan<=2; kan++)
		{System.out.println(arr2[0][kan] + "\t");} System.out.println();
		
		for(int kan=0; kan<=2; kan++)
		{System.out.println(arr2[1][kan] + "\t");} System.out.println();
		
		System.out.println();
		System.out.println();
		// ver-3
		for(int ch=0; ch<=2; ch++) {
			for(int ch1=0; ch1<=2; ch1++) {
				System.out.println(arr2[ch][ch1]+"\t");} System.out.println();}
		
			
		//ver-4
		//배열명 (아파트) .length 층 // 배열명[0](층).length
		for(int ch=0; ch<arr2.length; ch++) {
			for(ch=0; ch<arr2.length; ch++) {System.out.println(arr2[ch][ch]+ "\t");}
		System.out.println();}
	}

}
