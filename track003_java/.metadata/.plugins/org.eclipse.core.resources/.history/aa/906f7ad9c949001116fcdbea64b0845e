package basic.basic015_ex_;

interface Printer { void print(String msg);

void print(String msg, Calculator c1); }

interface Calculator { int add(int a, int b); }


public class LambdaEx001 {
	public static void main(String[] args) {
		
		//1. 익명객체 - 매개변수 O, 리턴값 X
		Printer p1 = new Printer() {
			@Override
			public void print(String msg) {
				System.out.println("Message: " + msg);
			}

			@Override
			public void print(String msg, Calculator c1) { 
				System.out.println("익명객체 결과: " + c1.add(3, 5));  
			}
		};
		p1.print("Hello World");
		
		//2. 람다식 - 매개변수 O, 리턴값 X
		Printer p2 = msg -> System.out.println("Message: " + msg);
		p2.print("Lambda Rocks!");
		
		//3. 익명객체 - 매개변수 O, 리턴값 O
		Calculator c1 = new Calculator() {
			@Override
			public int add(int a, int b) {
				return a + b;
			}
		};
		
		//4. 람다식 - 매개변수 O, 리턴값 O
		Calculator c2 = (a, b) -> a + b;
		
		//Printer의 오버로드 메서드 호출
		Printer p3 = new Printer() {
			@Override
			public void print(String msg) {}
			
			@Override
			public void print(String msg, Calculator c) {
				System.out.println("람다식 결과: " + c.add(10, 20));
			}
		};
		p3.print("", c2);

	}
}

/*

문제 1: 매개변수 O, 리턴값 X
설명: 문자열을 받아서 출력하는 기능을 구현하세요.
인터페이스 이름: Printer
메서드: void print(String msg)

요구사항:
익명 객체로 "Message: <문자열>" 형식으로 출력하기
람다식으로 동일한 기능 구현하기
 
문제 2: 매개변수 O, 리턴값 O
설명: 두 정수를 받아 합을 반환하는 기능을 구현하세요.
인터페이스 이름: Calculator
메서드: int add(int a, int b)

요구사항:
익명 객체로 두 수의 합을 반환하기
람다식으로 동일한 기능 구현하기

출력내용 : 
Message: Hello World
Message: Lambda Rocks!

익명객체 결과: 8
람다식 결과: 30
*/